# --- FPT AI Factory (LLM Provider) ---
# Set the API Key provided by the sponsor
FPT_AI_FACTORY_API_KEY=your_fpt_ai_factory_api_key_here
# Usually FPT AI Factory uses an OpenAI compatible endpoint (e.g. https://api.fpt.ai/v1/ or custom domain)
FPT_AI_FACTORY_BASE_URL=https://api.fpt.ai/v1
FPT_AI_FACTORY_MODEL=gpt-4o-mini # Update with the official model name supplied at the event

# --- Google Gemini API (Fallback or alternative) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Postgres Database ---
POSTGRES_DB=hackathon_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_123
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_password_123@postgres:5432/hackathon_db

# --- Redis Cache ---
REDIS_URL=redis://redis:6379/0

# --- Vector Database (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=optional_qdrant_api_key
QDRANT_COLLECTION_NAME=hospital_approved_documents

# --- Hospital Integration URLs ---
HOSPITAL_BOOKING_WEBSITE_URL=https://booking.hanoi-heart-hospital.example/appointments
HOSPITAL_ZALO_MINI_APP_URL=https://zalo.me/s/hanoi-heart-hospital-booking
HOSPITAL_CUSTOMER_SERVICE_HOTLINE=tel:19000000

# --- Application Server ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
