# ============================================
# Hanoi Heart Hospital Platform - Environment Configuration
# ============================================
# Copy this file to .env.local and update with your actual values
# This file is NOT ignored by git - do not commit secrets here
# Use .env.local (in .gitignore) for local development with real secrets

# ============================================
# Next.js Configuration
# ============================================

# Environment mode
NODE_ENV=development

# ============================================
# API Configuration
# ============================================

# Base URL for API calls from frontend (accessible in browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Backend API URL (used by Next.js server-side)
# Leave empty to use same host as frontend
BACKEND_API_URL=http://localhost:3000/api

# ============================================
# AI Agent Configuration
# ============================================

# Python AI Agent endpoint for RAG & chatbot
PYTHON_AGENT_URL=http://localhost:8000

# AI Agent API key (if authentication required)
PYTHON_AGENT_API_KEY=

# Timeout for AI agent requests (milliseconds)
AI_AGENT_TIMEOUT=30000

# ============================================
# Hospital Metadata
# ============================================

# Hospital name
NEXT_PUBLIC_HOSPITAL_NAME=Bệnh viện Tim Hà Nội

# Hospital code (internal identifier)
NEXT_PUBLIC_HOSPITAL_CODE=HANOI_HEART_01

# Hospital phone number
NEXT_PUBLIC_HOSPITAL_PHONE=+84-24-XXXX-XXXX

# Hospital address
NEXT_PUBLIC_HOSPITAL_ADDRESS=Hanoi, Vietnam

# ============================================
# Authentication & Security
# ============================================

# JWT Secret (for session management if implemented)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-production

# OAuth providers (if using authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session timeout (minutes)
SESSION_TIMEOUT=30

# ============================================
# Database Configuration
# ============================================

# Database URL (if connecting to real database instead of mock data)
DATABASE_URL=

# Database username (if applicable)
DATABASE_USER=

# Database password (if applicable)
DATABASE_PASSWORD=

# ============================================
# Email Configuration (for notifications)
# ============================================

# Email service provider (smtp, sendgrid, mailgun, aws-ses)
EMAIL_PROVIDER=smtp

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# From email address
EMAIL_FROM=noreply@hanoi-heart-hospital.vn

# Appointment reminder email template ID (if using template service)
EMAIL_TEMPLATE_APPOINTMENT_REMINDER=

# Medication reminder email template ID
EMAIL_TEMPLATE_MEDICATION_REMINDER=

# ============================================
# SMS Configuration (for notifications)
# ============================================

# SMS provider (twilio, vonage, aws-sns)
SMS_PROVIDER=

# SMS API credentials
SMS_API_KEY=
SMS_API_SECRET=

# From phone number
SMS_FROM_NUMBER=

# ============================================
# Logging & Monitoring
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Sentry DSN (error tracking) - optional
SENTRY_DSN=

# Sentry environment
SENTRY_ENVIRONMENT=development

# Analytics provider (google, mixpanel, amplitude)
ANALYTICS_PROVIDER=

# Analytics tracking ID
ANALYTICS_TRACKING_ID=

# ============================================
# Feature Flags
# ============================================

# Enable AI chatbot
NEXT_PUBLIC_ENABLE_CHATBOT=true

# Enable staff operations board
NEXT_PUBLIC_ENABLE_STAFF_BOARD=true

# Enable appointment scheduling
NEXT_PUBLIC_ENABLE_APPOINTMENTS=true

# Enable medication reminders
NEXT_PUBLIC_ENABLE_MEDICATION_REMINDERS=true

# Enable emergency escalation (3-min flag system)
NEXT_PUBLIC_ENABLE_EMERGENCY_ESCALATION=true

# Enable human-in-the-loop dashboard for staff
NEXT_PUBLIC_ENABLE_HUMAN_LOOP_DASHBOARD=true

# Use mock data (development) or real API
NEXT_PUBLIC_USE_MOCK_DATA=true

# ============================================
# RAG & Document Configuration
# ============================================

# Path to hospital procedure documents (for RAG)
RAG_DOCUMENTS_PATH=./documents/procedures

# Vector database URL (for embeddings if using Pinecone, Weaviate, etc.)
VECTOR_DB_URL=

# Vector database API key
VECTOR_DB_API_KEY=

# Embedding model (openai, huggingface, local)
EMBEDDING_MODEL=

# ============================================
# Third-party Services
# ============================================

# OpenAI API key (if using GPT for AI features)
OPENAI_API_KEY=

# OpenAI model (gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI organization ID (optional)
OPENAI_ORG_ID=

# ============================================
# Performance & Caching
# ============================================

# Redis URL (for caching, sessions if implemented)
REDIS_URL=

# Cache TTL (seconds)
CACHE_TTL=3600

# ============================================
# Development Tools
# ============================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Development server port
PORT=3000

# ============================================
# Application URLs
# ============================================

# Frontend URL (for external references)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backoffice/Admin URL
NEXT_PUBLIC_ADMIN_URL=

# Support/Help URL
NEXT_PUBLIC_HELP_URL=https://help.hanoi-heart-hospital.vn

# Privacy policy URL
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy

# Terms of service URL
NEXT_PUBLIC_TERMS_URL=/terms

# ============================================
# Compliance & Legal
# ============================================

# HIPAA compliance mode (if handling real patient data)
HIPAA_COMPLIANCE_ENABLED=false

# Data retention period (days)
DATA_RETENTION_DAYS=365

# Patient consent required before chatbot
REQUIRE_PATIENT_CONSENT=true

# ============================================
# Notes
# ============================================
# For production deployment:
# 1. Copy this file to .env.local
# 2. Update all values with production credentials
# 3. NEVER commit .env.local to version control
# 4. Use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)
# 5. Rotate secrets regularly
# 6. Enable HIPAA compliance mode if handling patient data
# 7. Set up monitoring and logging for security events
